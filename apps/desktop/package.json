{
  "name": "@poc2/desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Path of Crafting 2 — desktop shell (Electron) around the apps/web static export. ADR-0010.",
  "main": "dist/main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev": "bun run build && bun scripts/run-electron.mjs --dev",
    "start": "bun run build && bun scripts/run-electron.mjs",
    "test": "bun test",
    "dist:linux": "bun run build && electron-builder --linux",
    "dist:win": "bun run build && electron-builder --win"
  },
  "trustedDependencies": ["electron"],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  }
}
