# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Node
node_modules/
dist/
.pnpm-store/
*.tsbuildinfo

# Tauri
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/Cargo.lock
# dist/ is generated by `pnpm build` but we keep a placeholder for cold-start
apps/desktop/dist/*
!apps/desktop/dist/index.html

# Per-base art icons fetched by `cargo run -p poc2-pipeline --bin fetch-base-icons`.
# These are downloaded locally per-developer; the script must be re-run to regenerate.
apps/desktop/public/base-icons/

# Editors / IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
.DS_Store

# direnv
.direnv/
.env
.env.local

# Nix
result
result-*

# Logs
*.log
logs/

# Local data / caches
data/cache/
data/bundles/
.poc2-cache/

# Generated / artefacts
*.bundle.json
*.bundle.json.gz

# example-repos: reference-only clones, NOT tracked.
# See example-repos/README.md for the full list and clone instructions.
example-repos/*
!example-repos/README.md
