# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Node / web (Bun workspace; the web app's build outputs — see also apps/web/.gitignore)
node_modules/
.next/
out/
*.tsbuildinfo

# Generated WebAssembly engine (rebuild with `bash scripts/build-wasm.sh`).
# Mirrors apps/web/.gitignore so a stray copy is never committed at the root.
apps/web/lib/wasm/
apps/web/public/wasm/

# Electron desktop shell (ADR-0010) — compiled main/preload JS + packaged installers.
# `apps/desktop/build/` (icons) IS tracked; only the build *outputs* are ignored.
apps/desktop/dist/
apps/desktop/dist-packages/

# Per-base art icons fetched by `cargo run -p poc2-pipeline --bin fetch-base-icons`.
# These are downloaded locally per-developer; the script must be re-run to regenerate.
apps/desktop/public/base-icons/

# Editors / IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
.DS_Store

# direnv
.direnv/
.env
.env.local

# Nix
result
result-*

# Logs
*.log
logs/

# Local data / caches
data/cache/
data/bundles/
.poc2-cache/

# Generated / artefacts
*.bundle.json
*.bundle.json.gz

# example-repos: reference-only clones, NOT tracked.
# See example-repos/README.md for the full list and clone instructions.
example-repos/*
!example-repos/README.md

# Agent worktrees / scratch (opencode / claude-code session state).
.claude/

# spike/ — overlay-prototype research (electrobun / gtk4-layer-shell / iced /
# x11-overlay experiments). Exploratory, superseded by the Electron shell
# (ADR-0010); kept locally for reference, not part of the product build.
spike/
